# ─────────────────────────────────────────────────────────
#  NOVA-Lada — Variables d'environnement
#  ⚠️ Copier en .env (jamais commité). En prod : Coolify env vars.
# ─────────────────────────────────────────────────────────

# Stripe
STRIPE_API_KEY=rk_live_REPLACE_ME              # Restricted key (Read sur Payment Intents + Checkout Sessions + Customers)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME         # Signing secret du webhook (dashboard.stripe.com → Webhooks)

# Brevo
BREVO_API_KEY=xkeysib-REPLACE_ME               # API key Brevo (Paramètres → SMTP & API)
BREVO_TEMPLATE_CONFIRMATION_ID=2
BREVO_TEMPLATE_EXPEDITION_ID=3
BREVO_TEMPLATE_AVIS_ID=4

# Admin (pour déclencher templates 2 et 3 manuellement)
# Générer avec : python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_TOKEN=REPLACE_ME_WITH_LONG_RANDOM_STRING

# Misc
ENVIRONMENT=production                          # production | staging | dev
LOG_LEVEL=INFO
DEFAULT_SHIPPING_DAYS=4                         # Délai estimé de livraison en jours ouvrés
